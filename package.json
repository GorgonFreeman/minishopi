{
  "name": "minishopi",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "start": "node --env-file=.env server.js",
    "dev": "vite build && concurrently -k \"npm run build:watch\" \"npm start\"",
    "tunnel": "cloudflared tunnel --url http://localhost:3121",
    "shopify:build": "npx --yes @shopify/cli@latest app build"
  },
  "dependencies": {
    "@shopify/polaris": "^13.9.5",
    "@shopify/shopify-api": "^13.0.0",
    "@upstash/redis": "^1.37.0",
    "cloudflared": "^0.7.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "vite": "^6.3.5"
  }
}
