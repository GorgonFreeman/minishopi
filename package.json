{
  "name": "kitsuchan",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "vite build",
    "start": "node --env-file=.env server.js",
    "web:dev": "vite build && concurrently -k \"vite build --watch\" \"node server.js\"",
    "dev": "shopify app dev",
    "deploy": "node --env-file=.env scripts/deploy.mjs",
    "new": "node scripts/new.mjs",
    "clear-sessions": "node --env-file=.env scripts/clear-kitsuchan-sessions.mjs"
  },
  "dependencies": {
    "@preact/signals": "^2.9.0",
    "@shopify/shopify-api": "^13.0.0",
    "@shopify/ui-extensions": "2025.10.14",
    "@upstash/redis": "^1.37.0",
    "lit": "^3.3.2",
    "preact": "^10.29.2"
  },
  "devDependencies": {
    "@shopify/cli": "^3.94.3",
    "concurrently": "^9.2.1",
    "vite": "^6.3.5"
  }
}
