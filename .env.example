SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
HOST=https://your-tunnel.trycloudflare.com
PORT=3121
# Must match the scopes merchants actually grant at install — use the same list as shopify.app.toml [access_scopes].
SCOPES=read_products,write_products,read_metaobjects
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: public app URL if not the default *.run.app (custom domain). Used for HOST on Cloud Run and shopify.app.live.toml.
# GCP_PUBLIC_APP_URL=https://app.example.com

# After Cloud Run deploy: set SHOPIFY_APP_DEPLOY=1 to run `shopify app deploy -c live` (updates Partners App URL + redirects). Requires Shopify CLI auth.
# SHOPIFY_APP_DEPLOY=1

# Google Cloud Run — npm run deploy reads GCP_* below plus forwards almost every other key from this file to the service (see scripts/gcp-deploy.mjs). PORT, HOST, HOSTED_URL, and GCP_* deploy knobs are omitted from the initial bundle; HOST is patched after deploy to the service URL. A generated HOSTED_URL line is written back after deploy.
GCP_PROJECT=
GCP_REGION=us-central1
# Defaults to package.json "name" if unset.
# GCP_SERVICE=kitsuchan
GCP_ALLOW_UNAUTHENTICATED=true
# Optional: GCP_MEMORY=512Mi GCP_CPU=1 GCP_MIN_INSTANCES=0 GCP_MAX_INSTANCES=10 GCP_TIMEOUT=300 GCP_CONCURRENCY=80
# Optional: run service account email (Workload Identity / secret access).
# GCP_SERVICE_ACCOUNT=kitsuchan@PROJECT_ID.iam.gserviceaccount.com
# Optional: comma-separated extra KEY names in .env to omit from Cloud Run (in addition to PORT and GCP_* deploy keys).
# GCP_DEPLOY_ENV_EXCLUDE=MY_LOCAL_ONLY_FLAG
