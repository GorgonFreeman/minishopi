SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# `shopify app dev` overrides HOST with the dev tunnel URL automatically; set this for `npm start` standalone runs.
HOST=https://your-prod.example.com
PORT=3121
# Must match shopify.app.toml [access_scopes].
SCOPES=read_products,write_products,read_customers,read_metaobjects,read_themes,write_themes
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# `npm run deploy` (gcloud must be authenticated: gcloud auth login; gcloud config set project …).
GCP_PROJECT=
# Required: must match the Cloud Run region where the service runs (deploy script defaults to us-central1).
GCP_REGION=australia-southeast1
# Optional: pin the public URL when prediction/describe is wrong; must match Cloud Run status.url / HOST.
# GCP_PUBLIC_APP_URL=https://kitsuchan...run.app
# Optional: defaults to package.json "name".
# GCP_SERVICE=kitsuchan
